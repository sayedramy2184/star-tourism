# ─────────────────────────────────────────────
#  ÉLITE DRIVE — Variables d'environnement
#  Copier ce fichier en .env.local
#  Ne jamais committer .env.local sur GitHub !
# ─────────────────────────────────────────────

# ── Supabase ──────────────────────────────────
# Trouve ces valeurs dans : Supabase > Settings > API

NEXT_PUBLIC_SUPABASE_URL=https://VOTRE_PROJECT_ID.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=VOTRE_ANON_KEY

# Clé secrète — uniquement côté serveur (API routes)
# Ne jamais préfixer avec NEXT_PUBLIC_
SUPABASE_SERVICE_ROLE_KEY=VOTRE_SERVICE_ROLE_KEY

# ── App ───────────────────────────────────────
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_APP_NAME=Élite Drive

# ── En production (Vercel) ────────────────────
# NEXT_PUBLIC_APP_URL=https://app.elitedrive.fr
